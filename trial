<!DOCTYPE html>
<html>
<head>
  <title>練習ページ</title>

  <style>
  body {
    font-family: sans-serif;
    background: #f5f5f5;
    text-align: center;
  }

  .box {
    background: white;
    padding: 20px;
    margin: 40px auto;
    width: 300px;
    border-radius: 10px;
  }

  button {
    background: blue;
    color: white;
    padding: 10px;
    border: none;
    border-radius: 5px;
  }
  </style>

</head>

<body>

<div class="box">
  <h1>はじめてのページ</h1>
  <p>これは練習用のサイトです</p>

  <button onclick="alert('押されました')">
    クリック
  </button>
</div>

</body>
</html>
